{
  "compilerOptions": {
    // "ignoreDeprecations": "6.0",
    "skipLibCheck": true,
    "module": "commonjs",
    "target": "ES2020",
    "declaration": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictFunctionTypes": false,
    "resolveJsonModule": true,
    "sourceMap": true,
    "strict": true,
    "types": ["mocha"],
    "typeRoots": ["./node_modules/@types"],
    "rootDir": ".",
    "outDir": "dist",
    // "typeRoots": [
    //   "./node_modules/@types",
    //   "../lubejs-mssql/typings",
    //   "./typings"
    // ],
    "paths": {
      // "lubejs": ["../lubejs/src"],
      // "lubejs/*": ["../lubejs/src/*"],
      // "lubejs-mssql": ["../lubejs-mssql/src"],
      // "lubejs-mssql/*": ["./lubejs-mssql/src/*"],
      // "orm": ["./orm-decorator/index"],
      // "orm/*": ["./orm-decorator/*"],
      "@orm": [
        "./orm-configure"
      ],
      "@orm/*": [
        "./orm-configure/*"
      ],
      "@lubejs-driver": [
        "./node_modules/lubejs-mssql"
      ],
      "@lubejs-driver/*": [
        "./node_modules/lubejs-mssql/*"
      ]
    }
  },
  "include": [
    ".lubejs.ts",
    "./tests/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
