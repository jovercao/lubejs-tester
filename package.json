  "devDependencies": {
    "@types/crypto-js": "^4.0.2",
    "@types/lodash": "^4.14.170",
    "@types/mocha": "^8.2.2",
    "@types/mockjs": "^1.0.3",
    "@types/mssql": "^6.0.8",
    "@types/node": "^14.17.14",
    "@typescript-eslint/eslint-plugin": "^4.30.0",
    "@typescript-eslint/parser": "^4.30.0",
    "cross-env": "^7.0.3",
    "eslint": "^6.8.0",
